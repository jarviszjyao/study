{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["dataset"],
  "properties": {
    "dataset": { "type": "string" },
    "filters": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    }
  }
}
